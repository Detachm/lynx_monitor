# Copy to infra/production.env and fill the absolute host paths before starting.

# For Thursday, May 28, 2026. Leave empty to use the container's Asia/Shanghai date at startup.
RUNTIME_TRADE_DATE=20260528

# Start runtime before the open so xtquant is connected and subscribed by 09:30.
RUNTIME_START_AT=09:25
WAIT_FOR_MARKET_START=true

# Absolute host paths.
SILVER_ROOT=/absolute/path/to/mammoth-silver
XTQUANT_SDK_PATH=/home/hliu/xtbackend/vendor/xtquant_251211_interim-release_cp36m-37m-38-39-310-311-312_linux-gnu_x86_64
XTQUANT_DATA_HOME=/home/hliu/xtbackend/.runtime/xtquant

# Optional. If xtquant needs a token and it is not already in the mounted config, set it here.
XTQUANT_TOKEN=

# Active pool defaults.
ACTIVE_POOL_TARGET_SIZE=200
ACTIVE_POOL_PINNED_MAX_SIZE=100
ACTIVE_POOL_RANK_WINDOW_DAYS=5
ACTIVE_POOL_RANK_METRIC=avg_turnover

# Capacity and availability defaults.
KAFKA_BOOTSTRAP_SERVERS=127.0.0.1:19092
KAFKA_RETENTION_MS=86400000
KAFKA_RAW_RETENTION_BYTES=5368709120
KAFKA_PROCESSED_RETENTION_BYTES=5368709120
ALLOW_KAFKA_DEGRADED=true
REDIS_MAXMEMORY=1gb
REDIS_MAXMEMORY_POLICY=volatile-ttl
REDIS_HISTORY_TTL_SECONDS=604800
RUNTIME_HEALTH_MAX_AGE_SECONDS=30
MIN_ARTIFACT_FREE_BYTES=21474836480
WARN_ARTIFACT_FREE_BYTES=107374182400

# Optional frontend initial watchlist. Active pool generation is backend-side.
VITE_MARKET_SYMBOLS=00700.HK,00939.HK,02643.HK,00108.HK

# Leave false for live pulling.
DISABLE_XTQUANT=false
DISABLE_DUCKDB=false
HYDRATE_HISTORICAL_ALERTS=false
