{
  "extends": "@tsconfig/node24/tsconfig.json",
  "include": ["electron/**/*.ts"],
  "compilerOptions": {
    "composite": true,
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.electron.tsbuildinfo",
    "rootDir": "electron",
    "outDir": "dist-electron",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "types": ["node"],
    "noEmit": false
  }
}
